#!/usr/bin/env bash
# Backward-compatible launcher. The product is now named clawkit.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="$SCRIPT_DIR/clawkit-cli/target/clawkit-cli-0.1.0-SNAPSHOT.jar"

if [ ! -f "$JAR" ]; then
    echo "[deprecated] miniclaw is now clawkit; building clawkit..."
    cd "$SCRIPT_DIR"
    mvn package -pl clawkit-cli -am -q -DskipTests
fi

exec java -Dfile.encoding=UTF-8 -jar "$JAR" "$@"
