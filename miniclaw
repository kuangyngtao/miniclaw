#!/usr/bin/env bash
# Backward-compatible launcher. The product is now named clawkit.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="$(find "$SCRIPT_DIR/clawkit-cli/target" -maxdepth 1 -type f \
    -name 'clawkit-cli-*.jar' ! -name 'original-*' -print -quit 2>/dev/null || true)"

if [ -z "$JAR" ]; then
    echo "[deprecated] miniclaw is now clawkit; building clawkit..."
    cd "$SCRIPT_DIR"
    mvn package -pl clawkit-cli -am -q -DskipTests
    JAR="$(find "$SCRIPT_DIR/clawkit-cli/target" -maxdepth 1 -type f \
        -name 'clawkit-cli-*.jar' ! -name 'original-*' -print -quit)"
fi

exec java -Dfile.encoding=UTF-8 -jar "$JAR" "$@"
